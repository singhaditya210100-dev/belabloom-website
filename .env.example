// Environment variables for your project
// Copy this to .env.local and fill in your actual values

# Email Configuration (Choose one email service)
# SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# NEXT_PUBLIC_SENDGRID_FROM_EMAIL=noreply@belabloom.com

# Resend
# RESEND_API_KEY=your_resend_api_key_here

# Nodemailer (for custom SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Application Settings
NEXT_PUBLIC_APP_NAME="Belabloom"
NEXT_PUBLIC_APP_URL="https://www.belabloom.com"

# Contact Email
NEXT_PUBLIC_CONTACT_EMAIL=info@belabloom.com

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=your_google_analytics_id
